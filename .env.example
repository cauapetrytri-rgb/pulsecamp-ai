# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ORIGIN=http://localhost:3000
DATABASE_PATH=.data/pulsecamp.db
SESSION_SECRET=replace-with-at-least-32-random-characters
# Optional production user store. Use scrypt hashes; public demo users are used when omitted.
AUTH_USERS_JSON=

# OpenAI (optional: without a key, the app uses a deterministic demo classifier)
OPENAI_API_KEY=
OPENAI_QUALIFICATION_MODEL=gpt-5.4-mini
LEAD_QUALIFICATION_THRESHOLD=70

# WhatsApp Cloud API webhook
WHATSAPP_VERIFY_TOKEN=replace-with-a-long-random-token
META_APP_SECRET=
META_TOKEN_ENCRYPTION_KEY=replace-with-at-least-32-random-characters

# Meta Conversions API for Business Messaging
META_GRAPH_API_VERSION=v25.0
META_CAPI_DRY_RUN=true
META_TEST_EVENT_CODE=

# Per-client secrets. Production should use a secrets manager.
META_CAPI_TOKEN_SOLAR_PRIME=
META_CAPI_TOKEN_ALFA_IMOVEIS=
META_CAPI_TOKEN_ORBE_AUTO=
